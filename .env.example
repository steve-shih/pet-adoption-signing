# ==========================================
# Pet Adoption Backend Environment Configuration
# ==========================================

# 1. Local Standalone Mode (本機開發)
# MONGODB_URI=mongodb://127.0.0.1:27017/pet-adoption

# 2. Local K8s Mode (本機 K8s 容器內部)
# MONGODB_URI=mongodb://host.docker.internal:27017/pet-adoption

# 3. Production K8s Mode (GCP 正式雲端)
# MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/pet-adoption?retryWrites=true&w=majority

MONGODB_URI=mongodb://127.0.0.1:27017/pet-adoption
